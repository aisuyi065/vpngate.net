VPNGATE_BIND_HOST=0.0.0.0
VPNGATE_BIND_PORT=8000
VPNGATE_DATA_DIR=./data
VPNGATE_RUNTIME_MODE=openvpn
VPNGATE_DASHBOARD_PASSWORD=
VPNGATE_DASHBOARD_SESSION_SECRET=
VPNGATE_CONNECTOR_MODE=openvpn
VPNGATE_IP_INTEL_PROVIDER=ipapi.is
VPNGATE_REFRESH_INTERVAL_SECONDS=3600
VPNGATE_HEARTBEAT_INTERVAL_SECONDS=60
VPNGATE_QUALITY_TTL_SECONDS=86400
VPNGATE_MAX_QUALITY_LOOKUPS_PER_REFRESH=60
VPNGATE_CONNECT_TIMEOUT_SECONDS=45
VPNGATE_TUNNEL_HEALTH_STALE_SECONDS=20
VPNGATE_AUTO_MODE_DEFAULT_ENABLED=true
VPNGATE_AUTO_COUNTRIES=JP
VPNGATE_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
HYSTERIA_SERVICE_NAME=hysteria-server.service
HYSTERIA_CONFIG_DIR=/etc/hysteria
HYSTERIA_CONFIG_NAME=config.yaml
HYSTERIA_LISTEN_HOST=0.0.0.0
HYSTERIA_LISTEN_PORT=8443
HYSTERIA_TLS_MODE=self_signed
HYSTERIA_DOMAIN=
HYSTERIA_ACME_EMAIL=
HYSTERIA_AUTH_PASSWORD=
HYSTERIA_MASQUERADE_URL=https://bing.com
HYSTERIA_CERT_PATH=/etc/hysteria/server.crt
HYSTERIA_KEY_PATH=/etc/hysteria/server.key
HYSTERIA_CLIENT_SNI=bing.com
HYSTERIA_CLIENT_INSECURE=true
HYSTERIA_ADVERTISE_HOST=
